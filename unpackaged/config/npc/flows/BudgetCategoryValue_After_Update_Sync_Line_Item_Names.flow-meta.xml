<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Budget_Trigger_Handler</name>
        <label>Budget Trigger Handler</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>FlowToolKit__BudgetTriggerHandler_Invocable</actionName>
        <actionType>apex</actionType>
        <dataTypeMappings>
            <typeName>T__record</typeName>
            <typeValue>BudgetCategoryValue</typeValue>
        </dataTypeMappings>
        <dataTypeMappings>
            <typeName>T__priorRecord</typeName>
            <typeValue>BudgetCategoryValue</typeValue>
        </dataTypeMappings>
        <dataTypeMappings>
            <typeName>U__record</typeName>
            <typeValue>BudgetCategoryValue</typeValue>
        </dataTypeMappings>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>record</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>priorRecord</name>
            <value>
                <elementReference>$Record__Prior</elementReference>
            </value>
        </inputParameters>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <description>When a line item's name (Comments) changes, routes the change through the Flow Tool Kit Budget Trigger Handler, which syncs the new name to every Budget Category Value sharing the same Grouping Identifier and Budget Category. The entry filter is an efficiency gate only - the handler detects changes itself.</description>
    <environments>Default</environments>
    <interviewLabel>BudgetCategoryValue (After Update → Sync Line Item Names) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>BudgetCategoryValue (After Update → Sync Line Item Names)</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Budget_Trigger_Handler</targetReference>
        </connector>
        <filterFormula>AND(
  ISCHANGED({!$Record.Comments}),
  NOT(ISBLANK({!$Record.Grouping_Identifier__c}))
)</filterFormula>
        <object>BudgetCategoryValue</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
